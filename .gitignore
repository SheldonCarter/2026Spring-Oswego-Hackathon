# The virtual environment (the "box" we made)
recycle_env/
venv/
env/

# Python "behind-the-scenes" files
__pycache__/
*.py[cod]
*$py.class

# AI Model files (Don't upload 90MB+ files to Git!)
*.pth
*.pkl
*.bin
*.safetensors
*.onnx

# Hidden Mac files
.DS_Store

# Images you might use for testing
*.jpg
*.jpeg
*.png

# Node & Frontend dependencies
node_modules/
npm-debug.log
yarn-error.log

# Build folders
dist/
build/
.next/

# Environment variables (NEVER push your API keys!)
.env
.env.local
.env.development
.env.test
.env.production
